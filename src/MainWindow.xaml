<Window x:Class="LabiryntMatematyczny.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabiryntMatematyczny"
        mc:Ignorable="d"
        Title="Labirynt Matematyczny" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Grid Background="Black">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="200" />
        </Grid.ColumnDefinitions>

        <Canvas x:Name="gameCanvas" Grid.Column="0" />

        <Border x:Name="quizPanel" Grid.Column="0"
                Visibility="Hidden"
                Background="#333333"
                BorderBrush="White"
                BorderThickness="2"
                CornerRadius="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Width="400"
                Height="250">
            <StackPanel VerticalAlignment="Center" Margin="20">
                <Label x:Name="lblQuestion"
                       Content="Pytanie..."
                       Foreground="White"
                       FontSize="24"
                       HorizontalAlignment="Center"/>
                <TextBox x:Name="txtAnswer"
                         FontSize="20"
                         Width="100"
                         Margin="0,20,0,20"
                         TextAlignment="Center"/>
                <Button x:Name="btnSubmit"
                        Content="Sprawdź"
                        FontSize="18"
                        Width="150"
                        Click="btnSubmit_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Column="1" Background="#222222" BorderBrush="#444444" BorderThickness="2,0,0,0">
            <StackPanel Margin="10">
                <Label Content="MENU GRY" 
                       Foreground="White" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

                <Button Content="WZNÓW" 
                        Height="40" Margin="0,0,0,10" FontSize="16"
                        Click="BtnResume_Click"/>

                <Button Content="WSTRZYMAJ (PAUZA)" 
                        Height="40" Margin="0,0,0,10" FontSize="14"
                        Click="BtnPause_Click"/>

                <Button Content="RESTART POZIOMU" 
                        Height="40" Margin="0,0,0,10" FontSize="14"
                        Click="BtnRestart_Click"/>

                <Separator Margin="0,10,0,10" Background="Gray"/>

                <Button Content="EKRAN STARTOWY" 
                        Height="40" Margin="0,0,0,10" FontSize="14" Background="#AA3333" Foreground="White"
                        Click="BtnToStart_Click"/>

                <Separator Margin="0,20,0,10" Background="Gray"/>

                <Label Content="POZOSTAŁY CZAS:" 
                       Foreground="LightGray" 
                       FontSize="14" 
                       HorizontalAlignment="Center"/>

                <Label x:Name="lblTimer" 
                       Content="30" 
                       Foreground="Yellow" 
                       FontSize="40" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,0"/>

                <Separator Margin="0,20,0,10" Background="Gray"/>

                <Label Content="POZIOM:" 
                       Foreground="LightGray" 
                       FontSize="14" 
                       HorizontalAlignment="Center"/>

                <Label x:Name="lblLevel" 
                       Content="1" 
                       Foreground="Cyan" 
                       FontSize="40" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"/>

            </StackPanel>
        </Border>

        <Grid x:Name="menuGrid" Grid.ColumnSpan="2" Visibility="Visible">

            <Grid.Background>
                <ImageBrush ImageSource="/Assets/Images/menu_bg.jpg" Stretch="UniformToFill"/>
            </Grid.Background>

            <Rectangle Fill="Black" Opacity="0.5"/>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">

                <Label x:Name="lblMenuTitle" 
                       Content="LABIRYNT MATEMATYCZNY" 
                       Foreground="White" 
                       FontSize="40" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,50">
                    <Label.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="10" ShadowDepth="5"/>
                    </Label.Effect>
                </Label>

                <Label Content="Znajdź drogę do zielonego pola i rozwiąż zadanie!" 
                       Foreground="White" 
                       FontSize="16" 
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20">
                    <Label.Effect>
                        <DropShadowEffect Color="Black" BlurRadius="5"/>
                    </Label.Effect>
                </Label>

                <Button x:Name="btnMenuStart" 
                        Content="GRAJ" 
                        FontSize="30" 
                        Width="300" 
                        Height="60"
                        Click="BtnStartGame_Click"
                        BorderBrush="White"
                        BorderThickness="2">
                    <Button.Background>
                        <SolidColorBrush Color="Black" Opacity="0.7"/>
                    </Button.Background>
                    <Button.Foreground>White</Button.Foreground>
                </Button>

                <Button x:Name="btnBackToMenu"
                        Content="MENU STARTOWE" 
                        Visibility="Collapsed" 
                        FontSize="20" 
                        Width="200" 
                        Height="50"
                        Margin="0,20,0,0"
                        Click="BtnToStart_Click"
                        BorderBrush="White"
                        BorderThickness="2">
                    <Button.Background>
                        <SolidColorBrush Color="#AA3333" Opacity="0.8"/>
                    </Button.Background>
                    <Button.Foreground>White</Button.Foreground>
                </Button>
            </StackPanel>
        </Grid>

    </Grid>
</Window>